# Sao chép file này thành .env và điền thông tin thật vào

# ── Database backend ───────────────────────────────────────
# "sheets" = Google Sheets qua Apps Script Web App (mặc định, khuyến nghị)
# "supabase" = Supabase
DB_BACKEND=sheets

# ── Google Apps Script Web App ─────────────────────────────
# Lấy sau khi Deploy Web App trong Apps Script Editor
# Dạng: https://script.google.com/macros/s/XXXX/exec
GOOGLE_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec

# Token bảo mật — đặt giá trị tùy ý, phải khớp với Script Properties trong Apps Script
# Nếu để trống thì không xác thực (chỉ dùng khi test)
WEBAPP_SECRET=my_secret_token_123

# ── Supabase (chỉ cần nếu DB_BACKEND=supabase) ────────────
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_KEY=eyJhbGci...

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
